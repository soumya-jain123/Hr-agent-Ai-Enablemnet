# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=your_api_key

# ─── MongoDB ─────────────────────────────────────────────────
MONGO_URI=your_mongodb_uri

# ─── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Security ────────────────────────────────────────────────
# A secret key clients must send as x-api-key header
INTERNAL_API_KEY=your_internal_api_key

# ─── File Upload ─────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=uploads
